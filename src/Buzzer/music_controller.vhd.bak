--Pokemon
CONSTANT musica3 : vetor_pokemon := (
 (nota => E4,  tempo => ov3_t1_2), (nota => Ds4, tempo => ov3_t1_2), (nota => Cs4, tempo => ov3_t1_2),
 (nota => B3,  tempo => ov3_t1_2), (nota => A3,  tempo => ov3_t1_2), (nota => B3,  tempo => ov3_t1_2),
 (nota => Cs4, tempo => ov3_t1_2), (nota => Ds4, tempo => ov3_t1_2), (nota => E4,  tempo => ov3_t1),
 (nota => PAUSA, tempo => ov3_t1_4),
 (nota => E4,  tempo => ov3_t1_2), (nota => B3,  tempo => ov3_t1_2), (nota => Cs4, tempo => ov3_t1_2),
 (nota => Ds4, tempo => ov3_t1_2), (nota => E4,  tempo => ov3_t1_2), (nota => Fs4, tempo => ov3_t1_2),
 (nota => Gs4, tempo => ov3_t1_2), (nota => A4,  tempo => ov3_t1_2), (nota => Gs4, tempo => ov3_t1_2),
 (nota => A4,  tempo => ov3_t1_2), (nota => Gs4, tempo => ov3_t1_2), (nota => Fs4, tempo => ov3_t1),
 (nota => PAUSA, tempo => ov3_t1_4),
 (nota => E4,  tempo => ov3_t1_2), (nota => B3,  tempo => ov3_t1_2), (nota => Cs4, tempo => ov3_t1_2),
 (nota => Ds4, tempo => ov3_t1_2), (nota => E4,  tempo => ov3_t1_2), (nota => Fs4, tempo => ov3_t1_2),
 (nota => Gs4, tempo => ov3_t1_2), (nota => A4,  tempo => ov3_t1_2), (nota => Gs4, tempo => ov3_t1_2),
 (nota => E4,  tempo => ov3_t1_2), (nota => Gs4, tempo => ov3_t1_2), (nota => B4,  tempo => ov3_t1),
 (nota => PAUSA, tempo => ov3_t1_4),
 (nota => E4,  tempo => ov3_t1_2), (nota => B3,  tempo => ov3_t1_2), (nota => Cs4, tempo => ov3_t1_2),
 (nota => Ds4, tempo => ov3_t1_2), (nota => E4,  tempo => ov3_t1_2), (nota => Fs4, tempo => ov3_t1_2),
 (nota => Gs4, tempo => ov3_t1_2), (nota => A4,  tempo => ov3_t1_2), (nota => Gs4, tempo => ov3_t1_2),
 (nota => A4,  tempo => ov3_t1_2), (nota => Gs4, tempo => ov3_t1_2), (nota => Fs4, tempo => ov3_t1),
 (nota => PAUSA, tempo => ov3_t1_4),
 (nota => Gs3, tempo => ov3_t1), (nota => E4,  tempo => ov3_t1_2), (nota => B3,  tempo => ov3_t1_2),
 (nota => Cs4, tempo => ov3_t1_2), (nota => Ds4, tempo => ov3_t1_2), (nota => E4,  tempo => ov3_t1_2),
 (nota => Fs4, tempo => ov3_t1_2), (nota => Gs4, tempo => ov3_t1_2), (nota => A4,  tempo => ov3_t1_2),
 (nota => Gs4, tempo => ov3_t1_2), (nota => E4,  tempo => ov3_t1_2), (nota => Gs4, tempo => ov3_t1_2),
 (nota => B4,  tempo => ov3_t2)
);

CONSTANT musica4 : vetor_myway := (
 (nota => Fs4, tempo => ov4_t1), (nota => G4,  tempo => ov4_t1), (nota => A4,  tempo => ov4_t1), 
 (nota => A4,  tempo => ov4_t1), (nota => B4,  tempo => ov4_t1), (nota => A4,  tempo => ov4_t1), 
 (nota => Gs4, tempo => ov4_t1), (nota => A4,  tempo => ov4_t1), (nota => A4,  tempo => ov4_t1),
 (nota => A4,  tempo => ov4_t1), (nota => B4,  tempo => ov4_t1), (nota => B4,  tempo => ov4_t1),
 (nota => C5,  tempo => ov4_t1), (nota => B4,  tempo => ov4_t1), (nota => A4,  tempo => ov4_t1),
 (nota => B4,  tempo => ov4_t1), (nota => B4,  tempo => ov4_t1), (nota => Cs5, tempo => ov4_t1), 
 (nota => D5,  tempo => ov4_t1), (nota => D5,  tempo => ov4_t1), (nota => B4,  tempo => ov4_t1), 
 (nota => D5,  tempo => ov4_t1), (nota => B4,  tempo => ov4_t1), (nota => Cs5, tempo => ov4_t1),
 (nota => Cs5, tempo => ov4_t1), (nota => D5,  tempo => ov4_t1), (nota => E5,  tempo => ov4_t1),
 (nota => E5,  tempo => ov4_t1), (nota => Fs5, tempo => ov4_t1), (nota => Cs5, tempo => ov4_t1),
 (nota => E5,  tempo => ov4_t1), (nota => D5,  tempo => ov4_t1), (nota => B4,  tempo => ov4_t1),
 (nota => Cs4, tempo => ov4_t1), (nota => D5,  tempo => ov4_t1), (nota => D5,  tempo => ov4_t1),
 (nota => B4,  tempo => ov4_t1), (nota => D5,  tempo => ov4_t1), (nota => B4,  tempo => ov4_t1),
 (nota => Cs5, tempo => ov4_t1), (nota => Cs5, tempo => ov4_t1), (nota => D5,  tempo => ov4_t1),
 (nota => E5,  tempo => ov4_t1), (nota => E5,  tempo => ov4_t1), (nota => D5,  tempo => ov4_t1)
);

--FSM
	SIGNAL estado_atual : integer range 0 to 41 := 0; --Zelda - Lost Woods
	SIGNAL prox1        : integer range 0 to 32 := 0; --A-ha - Take On Me
	SIGNAL musica_atual : std_logic_vector(1 DOWNTO 0) := "00";
	
BEGIN
 L1: PROCESS(clk_in)
 BEGIN
  IF rising_edge(clk_in) THEN 
   estado_atual <= prox1;
   musica_atual <= selection;
  END IF;
 END PROCESS L1;
	
 L2: PROCESS(estado_atual, duration, stop_in, play_in, selection, musica_atual)
 VARIABLE limite : integer;
 BEGIN
  -- Seleciona limite do vetor conforme a música
  CASE selection IS
    WHEN "00" => limite := 41; -- Zelda - Lost Woods
    WHEN "01" => limite := 32; -- A-ha - Take On Me
    WHEN "10" => limite := 61; -- Pokemon - Cerulean Theme
    WHEN "11" => limite := 45; -- Frank Sinatra - My Way
	END CASE;
  IF selection /= musica_atual THEN
   prox1 <= 0;
  ELSIF stop_in = '1' THEN
   prox1 <= 0;
  ELSE
   IF (duration = '0' AND play_in = '1') THEN
    IF (estado_atual = limite) THEN
     prox1 <= 0; 
    ELSE
     prox1 <= estado_atual + 1; 
    END IF;
   ELSE
    prox1 <= estado_atual; 
   END IF;
  END IF;
 END PROCESS L2;
 
 L3: PROCESS (clk_in)
 BEGIN
  IF rising_edge(clk_in) THEN
   IF play_in = '0' THEN
    nota(PAUSA, 0);  -- buzzer parado
   ELSE
    CASE selection IS
    WHEN "00" =>
        nota(musica1(estado_atual).nota, musica1(estado_atual).tempo);
    WHEN "01" =>
        nota(musica2(estado_atual).nota, musica2(estado_atual).tempo);
    WHEN "10" =>
        nota(musica3(estado_atual).nota, musica3(estado_atual).tempo);
    WHEN OTHERS =>
        nota(musica4(estado_atual).nota, musica4(estado_atual).tempo);
    END CASE;
   END IF;
  END IF;
 END PROCESS L3;

  clk_out <= duration AND clk_in;
  
END arc;