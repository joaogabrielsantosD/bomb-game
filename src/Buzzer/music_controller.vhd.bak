LIBRARY IEEE;
USE IEEE.std_logic_1164.ALL;
USE IEEE.numeric_std.ALL;
ENTITY music_controller IS
PORT (clk_out, pop : OUT std_logic := '0';
		temp_out, freq_out : OUT std_logic_vector(27 DOWNTO 0);
		clk_in, duration, stop_in, play_in : IN std_logic;
		selection : IN std_logic_vector(1 DOWNTO 0)
);
END music_controller;

ARCHITECTURE arc OF music_controller IS
  -- Aplicação do tempo e frequencia
  PROCEDURE nota (CONSTANT ov_f : IN integer;
						CONSTANT ov_t : IN integer ) IS
  BEGIN
		temp_out <= std_logic_vector(to_unsigned(ov_t,temp_out'LENGTH)); --duração			
		freq_out <= std_logic_vector(to_unsigned(ov_f,freq_out'LENGTH)); --frequência
		pop <= '1';  --dispara o temp a próxima nota	
  END nota;
	--clock principal da placa
	CONSTANT clk_FPGA : integer := 50000000; --50MHz
	--overflow para frequencias (50MHz)
   -- Fórmula: Overflow = (50MHz / (2*f)) - 1
	CONSTANT PAUSA : integer := 0; --buzzer parado
 
	CONSTANT C3 : integer := 95555; -- 261.63 Hz (Dó3)
	CONSTANT D3 : integer := 85130; -- 293.66 Hz (Ré3)
	CONSTANT E3 : integer := 75842; -- 329.63 Hz (Mi3)
	CONSTANT F3 : integer := 71585; -- 349.23 Hz (Fá3)
	CONSTANT G3 : integer := 63775; -- 392.00 Hz (Sol3)
	CONSTANT A3 : integer := 56817; -- 440.00 Hz (Lá3)
	CONSTANT B3 : integer := 50618; -- 493.88 Hz (Si3)
	CONSTANT Cs3 : integer := 90192; -- 277.18 Hz (Dó#3/Réb3)
	CONSTANT Ds3 : integer := 80349; -- 311.13 Hz (Ré#3/Mib3)
	CONSTANT Fs3 : integer := 67567; -- 369.99 Hz (Fá#3/Solb3)
	CONSTANT Gs3 : integer := 60166; -- 415.30 Hz (Sol#3/Láb3)
	CONSTANT As3 : integer := 53628; -- 466.16 Hz (Lá#3/Sib3)

	CONSTANT C4 : integer := 47777; -- 523.25 Hz (Dó4)
	CONSTANT D4 : integer := 42565; -- 587.33 Hz (Ré4)
	CONSTANT E4 : integer := 37921; -- 659.25 Hz (Mi4)
	CONSTANT F4 : integer := 35792; -- 698.46 Hz (Fá4)
	CONSTANT G4 : integer := 31887; -- 783.99 Hz (Sol4)
	CONSTANT A4 : integer := 28408; -- 880.00 Hz (Lá4)
	CONSTANT B4 : integer := 25308; -- 987.77 Hz (Si4)
	CONSTANT Cs4 : integer := 45096; -- 554.37 Hz (Dó#4/Réb4)
	CONSTANT Ds4 : integer := 40174; -- 622.25 Hz (Ré#4/Mib4)
	CONSTANT Fs4 : integer := 33783; -- 739.99 Hz (Fá#4/Solb4)
	CONSTANT Gs4 : integer := 30083; -- 830.61 Hz (Sol#4/Láb4)
	CONSTANT As4 : integer := 26813; -- 932.33 Hz (Lá#4/Sib4)

	CONSTANT C5 : integer := 23888; -- 1046.50 Hz (Dó5)
	CONSTANT D5 : integer := 21282; -- 1174.66 Hz (Ré5)
	CONSTANT E5 : integer := 18960; -- 1318.51 Hz (Mi5)
	CONSTANT F5 : integer := 17895; -- 1396.91 Hz (Fá5)
	CONSTANT G5 : integer := 15943; -- 1567.98 Hz (Sol5)
	CONSTANT A5 : integer := 14203; -- 1760.00 Hz (Lá5)
	CONSTANT B5 : integer := 12653; -- 1975.53 Hz (Si5)
	CONSTANT Cs5 : integer := 22547; -- 1108.73 Hz (Dó#5/Réb5)
	CONSTANT Ds5 : integer := 20087; -- 1244.51 Hz (Ré#5/Mib5)
	CONSTANT Fs5 : integer := 16891; -- 1479.98 Hz (Fá#5/Solb5)
	CONSTANT Gs5 : integer := 15041; -- 1661.22 Hz (Sol#5/Láb5)
	CONSTANT As5 : integer := 13406; -- 1864.66 Hz (Lá#5/Sib5)
	
	-- Constantes Zelda
	CONSTANT BPM1 : integer := 190; 
	CONSTANT BPS1 : integer := BPM1 / 60; 
	CONSTANT ov1_t4 : integer := (4 * clk_FPGA) / BPS1; 
	CONSTANT ov1_t3 : integer := (3 * clk_FPGA) / BPS1; 
	CONSTANT ov1_t2 : integer := (2 * clk_FPGA) / BPS1; 
	CONSTANT ov1_t1 : integer := clk_FPGA / BPS1; 
	CONSTANT ov1_t1_2 : integer := (clk_FPGA / 2) / BPS1; 
	CONSTANT ov1_t1_4	: integer := (clk_FPGA / 4) / BPS1;
	
	-- Constantes Take On Me
	CONSTANT BPM2 : integer := 200; 
	CONSTANT BPS2 : integer := BPM2 / 60; 
	CONSTANT ov2_t4 : integer := (4 * clk_FPGA) / BPS2; 
	CONSTANT ov2_t3 : integer := (3 * clk_FPGA) / BPS2; 
	CONSTANT ov2_t2 : integer := (2 * clk_FPGA) / BPS2; 
	CONSTANT ov2_t1 : integer := clk_FPGA / BPS2; 
	CONSTANT ov2_t1_2 : integer := (clk_FPGA / 2) / BPS2; 
	CONSTANT ov2_t1_4	: integer := (clk_FPGA / 4) / BPS2;
	
	-- Constantes Pokemom
	CONSTANT BPM3 : integer := 150; 
	CONSTANT BPS3 : integer := BPM3 / 60; 
	CONSTANT ov3_t4 : integer := (4 * clk_FPGA) / BPS3; 
	CONSTANT ov3_t3 : integer := (3 * clk_FPGA) / BPS3; 
	CONSTANT ov3_t2 : integer := (2 * clk_FPGA) / BPS3; 
	CONSTANT ov3_t1 : integer := clk_FPGA / BPS3; 
	CONSTANT ov3_t1_2 : integer := (clk_FPGA / 2) / BPS3; 
	CONSTANT ov3_t1_4	: integer := (clk_FPGA / 4) / BPS3;
	
	-- Constantes Pokemom
	CONSTANT BPM4 : integer := 110; 
	CONSTANT BPS4 : integer := BPM4 / 60; 
	CONSTANT ov4_t4 : integer := (4 * clk_FPGA) / BPS4; 
	CONSTANT ov4_t3 : integer := (3 * clk_FPGA) / BPS4; 
	CONSTANT ov4_t2 : integer := (2 * clk_FPGA) / BPS4; 
	CONSTANT ov4_t1 : integer := clk_FPGA / BPS4; 
	CONSTANT ov4_t1_2 : integer := (clk_FPGA / 2) / BPS4; 
	CONSTANT ov4_t1_4	: integer := (clk_FPGA / 4) / BPS4;
	
	--Partituras 
	TYPE partitura IS RECORD
		nota : integer;
		tempo : integer;
	END RECORD;
	TYPE vetor_zelda IS ARRAY (0 TO 41) OF partitura; -- Zelda - Lost Woods         (42)
	TYPE vetor_takeonme IS ARRAY (0 TO 32) OF partitura; -- A-ha - Take On Me       (33)
	TYPE vetor_pokemon IS ARRAY (0 TO 61) OF partitura; -- Pokemon - Cerulean Theme (62)
	TYPE vetor_myway IS ARRAY (0 TO 44) OF partitura; -- Frank Sinatra - My Way     (45)
	
--Zelda
CONSTANT musica1 : vetor_zelda := (
 (nota => PAUSA, tempo => ov1_t1),
 (nota => F4, tempo => ov1_t1), (nota => A4, tempo => ov1_t1), (nota => B4, tempo => ov1_t1),
 (nota => F4, tempo => ov1_t1), (nota => A4, tempo => ov1_t1), (nota => B4, tempo => ov1_t1),
 (nota => F4, tempo => ov1_t1), (nota => A4, tempo => ov1_t1), (nota => B4, tempo => ov1_t1), 
 (nota => E5, tempo => ov1_t1), (nota => D5, tempo => ov1_t1), (nota => B4, tempo => ov1_t1), 
 (nota => C5, tempo => ov1_t1), (nota => B4, tempo => ov1_t1), (nota => G4, tempo => ov1_t2), 
 (nota => E4, tempo => ov1_t1), (nota => D4, tempo => ov1_t1), (nota => E4, tempo => ov1_t1), 
 (nota => G4, tempo => ov1_t2), (nota => E4, tempo => ov1_t1_2), 
 (nota => PAUSA, tempo => ov1_t1),
 (nota => F4, tempo => ov1_t1), (nota => A4, tempo => ov1_t1), (nota => B4, tempo => ov1_t1),
 (nota => F4, tempo => ov1_t1), (nota => A4, tempo => ov1_t1), (nota => B4, tempo => ov1_t1),
 (nota => F4, tempo => ov1_t1), (nota => A4, tempo => ov1_t1), (nota => B4, tempo => ov1_t1), 
 (nota => E5, tempo => ov1_t1), (nota => D5, tempo => ov1_t1), (nota => B4, tempo => ov1_t1), 
 (nota => C5, tempo => ov1_t1), (nota => E5, tempo => ov1_t1), (nota => B4, tempo => ov1_t2), 
 (nota => G4, tempo => ov1_t1), (nota => B4, tempo => ov1_t1), (nota => G4, tempo => ov1_t1), 
 (nota => D4, tempo => ov1_t2), (nota => E4, tempo => ov1_t1)
 );
	
--Take On Me
