 (nota => PAUSA, tempo => ov2_t1_2),
 (nota => Fs4, tempo => ov2_t1_2), (nota => Fs4, tempo => ov2_t1_2), (nota => D4,  tempo => ov2_t1_2), 
 (nota => B3,  tempo => ov2_t1_2), (nota => PAUSA, tempo => ov2_t1_2), (nota => B3,  tempo => ov2_t1_2), 
 (nota => PAUSA, tempo => ov2_t1_2), (nota => E4,  tempo => ov2_t1_2), (nota => PAUSA, tempo => ov2_t1_2),
 (nota => E4,  tempo => ov2_t1_2), (nota => PAUSA, tempo => ov2_t1_2), (nota => E4,  tempo => ov2_t1_2),
 (nota => Gs4, tempo => ov2_t1_2), (nota => Gs4, tempo => ov2_t1_2), (nota => A4,  tempo => ov2_t1_2), 
 (nota => B4,  tempo => ov2_t1_2), (nota => A4,  tempo => ov2_t1_2), (nota => A4,  tempo => ov2_t1_2),
 (nota => A4,  tempo => ov2_t1_2), (nota => E4,  tempo => ov2_t1_2), (nota => PAUSA, tempo => ov2_t1_2),
 (nota => D4,  tempo => ov2_t1_2), 
 (nota => PAUSA, tempo => ov2_t1_2),
 (nota => Fs4, tempo => ov2_t1_2), (nota => PAUSA, tempo => ov2_t1_2), (nota => Fs4, tempo => ov2_t1_2),
 (nota => PAUSA, tempo => ov2_t1_2), (nota => Fs4, tempo => ov2_t1_2), (nota => E4,  tempo => ov2_t1_2),
 (nota => E4,  tempo => ov2_t1_2), (nota => Fs4, tempo => ov2_t1_2), (nota => E4,  tempo => ov2_t1_2)
